{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(curl:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(ss:*)",
      "Bash(python3 --version)",
      "Bash(claude --version)",
      "WebFetch(domain:github.com)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${HOME}/.claude/scripts/wrap-reminder.sh", "timeout": 5 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${HOME}/.claude/scripts/home-hygiene.sh" },
          { "type": "command", "command": "bash ${HOME}/.claude/scripts/git-status-check.sh" },
          { "type": "command", "command": "bash ${HOME}/.claude/scripts/openclaw-health.sh" },
          { "type": "command", "command": "python3 ${HOME}/.claude/scripts/wiki-sync-check.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ${HOME}/.claude/hooks/auto-format.sh", "timeout": 10 },
          { "type": "command", "command": "python3 ${HOME}/.claude/hooks/clear-image-cache.py", "timeout": 10 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ${HOME}/.claude/hooks/bash-audit.sh", "timeout": 5 }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ${HOME}/.claude/scripts/statusline.py"
  }
}
