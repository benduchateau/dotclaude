{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(curl:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(ss:*)",
      "Bash(wsl:*)",
      "WebFetch(domain:github.com)",
      "mcp__plugin_discord_discord__reply",
      "mcp__plugin_discord_discord__fetch_messages",
      "mcp__plugin_discord_discord__react",
      "mcp__plugin_discord_discord__edit_message",
      "mcp__plugin_discord_discord__download_attachment"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/scripts/wrap-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/scripts/home-hygiene.sh"
          },
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/scripts/git-status-check.sh"
          },
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/scripts/openclaw-health.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/hooks/auto-format.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 /home/duchats/.claude/hooks/clear-image-cache.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/duchats/.claude/hooks/bash-audit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 /home/duchats/.claude/scripts/statusline.py"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "codex@openai-codex": true,
    "telegram@claude-plugins-official": true,
    "discord@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "buildwithclaude": {
      "source": {
        "source": "git",
        "url": "https://github.com/davepoon/buildwithclaude.git"
      }
    },
    "claude-skills-marketplace": {
      "source": {
        "source": "github",
        "repo": "samuelgarrett/claude-code-plugin-test"
      }
    },
    "openai-codex": {
      "source": {
        "source": "git",
        "url": "https://github.com/openai/codex-plugin-cc.git"
      }
    }
  },
  "effortLevel": "high",
  "voiceEnabled": false,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
